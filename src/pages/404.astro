---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import sunrise from "../assets/photos/trigg-sunrise.jpg";
---

<Base
  title="Off course — FCTC"
  description="That page doesn't exist. Run it back to the start."
>
  <section class="lost">
    <div class="wrap lost-grid">
      <div data-rv>
        <p class="mono tag">404 — Off Course</p>
        <h1 class="display">You've run past the&nbsp;turnaround.</h1>
        <p class="sub">
          There's nothing out here but soft sand. Head back and we'll wait at
          the coffee.
        </p>
        <a class="btn" href="/">↜ Back to the start</a>
      </div>
      <figure class="duo">
        <Image
          src={sunrise}
          alt="Sunrise over the ocean at Trigg"
          widths={[480, 900]}
          sizes="(max-width: 900px) 92vw, 44vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>
</Base>

<style>
  .lost {
    padding-block: clamp(56px, 8vw, 110px);
  }
  .lost-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: center;
  }
  .tag {
    color: var(--pink);
    font-weight: 700;
  }
  h1 {
    font-size: clamp(44px, 6.5vw, 92px);
    margin-block: 12px 16px;
  }
  .sub {
    color: var(--ink-soft);
    margin-bottom: 32px;
    max-width: 30em;
  }
  .btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 2px solid var(--line);
    padding: 15px 28px;
    transition: transform 100ms ease, box-shadow 100ms ease;
  }
  .btn:hover {
    transform: translate(-3px, -3px);
    box-shadow: 5px 5px 0 var(--pink);
  }
  figure {
    border: 2px solid var(--line);
  }
  @media (max-width: 900px) {
    .lost-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
