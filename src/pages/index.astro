---
import { Image } from "astro:assets";
import Base, { LINKS } from "../layouts/Base.astro";
import Marquee from "../components/Marquee.astro";

import crewPhoto from "../assets/photos/wednesday-crew.jpg";
import singletPhoto from "../assets/photos/club-singlet.jpg";
import lidoPhoto from "../assets/photos/breakfast-il-lido.jpg";

// Strava group events — archived off the old Framer page; the club's only
// other record of these IDs is Strava itself.
const EVENTS = {
  wednesday: `${LINKS.strava}/group_events/1434762`,
  friday: `${LINKS.strava}/group_events/1434766`,
};

// Wednesday rotation by week of the month. The 5th week renders as
// rainbow letters (see .rainbow styles below).
const ROTATION = [
  { week: "1st", session: "Intervals" },
  { week: "2nd", session: "Herdy's + Monger 12km Cruise" },
  { week: "3rd", session: "Intervals" },
  { week: "4th", session: "8km Community Cruise" },
];
const SURPRISE = "Surprise?";

const FRIDAY = [
  { week: "Summer", session: "7–10km on the soft sand when the sand is warm" },
  { week: "Winter", session: "10km through the suburbs when it's cold" },
  { week: "MSBB", session: "Some Fridays we start at Mount Street Breakfast Bar in the CBD" },
];

const TRADITIONS = [
  {
    name: "Anzac Day Marathon",
    blurb: "A marathon on Anzac Day, because a dawn service deserves a dawn effort.",
  },
  {
    name: "Christmas Marathon",
    blurb: "The culmination of a year's training — capped off with the Christmas party and a White Elephant.",
  },
  {
    name: "Aaron's Birthday Beer Run",
    blurb: "What better way to celebrate than a half marathon with a few beers along the way?",
  },
  {
    name: "Birthday Halfs",
    blurb: "If it's your birthday, we run a half marathon in your honor.",
  },
];
---

<Base
  title="Filament Coffee Track Club"
  description="Perth run club. Wednesdays at Herdsman Lake 5:30am, Fridays at il Lido 6:00am. We warm up together, we drink coffee together — in between, run as fast, slow, or mental as you want."
>
  <!-- ============ hero ============ -->
  <section class="hero">
    <div class="wrap">
      <h1 class="display">
        <span class="line-clip"><span class="line">Filament</span></span>
        <span class="line-clip"><span class="line pink">Coffee</span></span>
        <span class="line-clip"><span class="line outline">Track Club</span></span>
      </h1>
      <div class="hero-meta">
        <span class="mono"><b>Perth WA</b> — Est. on a Wednesday</span>
        <span class="mono"><b>Wed 0530</b> Herdsman Lake</span>
        <span class="mono"><b>Fri 0600</b> il Lido, Cottesloe</span>
      </div>
      <div class="ctas">
        <a class="btn btn-solid" href={LINKS.whatsapp}>Join the WhatsApp</a>
        <a class="btn" href={LINKS.strava}>Strava Club</a>
      </div>
    </div>
    <div class="strip">
      <figure class="duo">
        <Image
          src={crewPhoto}
          alt="Wednesday crew running through Perth suburbs"
          widths={[480, 800, 1200]}
          sizes="(max-width: 900px) 92vw, 33vw"
          loading="eager"
        />
      </figure>
      <figure class="duo plain">
        <Image
          src={singletPhoto}
          alt="Runner in an FCTC singlet at golden hour"
          widths={[480, 800, 1200]}
          sizes="(max-width: 900px) 92vw, 33vw"
          loading="eager"
        />
      </figure>
      <figure class="duo">
        <Image
          src={lidoPhoto}
          alt="Post-run breakfast at il Lido"
          widths={[480, 800, 1200]}
          sizes="(max-width: 900px) 92vw, 33vw"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <Marquee text="FILAMENT COFFEE • COLD BREW • RUN" />

  <!-- ============ manifesto ============ -->
  <section class="manifesto">
    <div class="wrap">
      <p class="display creed" data-rv>
        We warm up together. We drink coffee together. In between, run as
        fast, slow, or <span class="out">mental</span> as you
        <span class="gold">want.</span>
      </p>
      <span class="stamp" id="stamp">★ Amen Scoundrels ★</span>
      <p class="creed-foot" data-rv>
        Balancing people's different fitness and social needs — we all run
        for different reasons, and everyone should get what they need out of
        our group sessions.
      </p>
    </div>
  </section>

  <!-- ============ weekly runs ============ -->
  <section class="section runs">
    <div class="wrap">
      <div class="kicker" data-rv>
        <h2 class="display">The Weekly Runs</h2>
        <span class="mono">Two starts. Zero alarms snoozed.</span>
      </div>
      <div class="run-grid" data-rv>
        <article class="run">
          <figure class="duo">
            <Image
              src={crewPhoto}
              alt="Wednesday crew mid-run"
              widths={[480, 800]}
              sizes="(max-width: 900px) 92vw, 45vw"
            />
          </figure>
          <div class="run-body">
            <div class="run-head">
              <h3 class="display">Wed</h3>
              <span class="bib">0530 · Herdsman Lake</span>
            </div>
            <p>
              Something for everyone. Easy some weeks, intervals and tempo
              others — everything at your own pace, all welcome.
            </p>
            <ul class="sched">
              {ROTATION.map(({ week, session }) => (
                <li><span class="wk">{week}</span><span>{session}</span></li>
              ))}
              <li>
                <span class="wk">5th</span>
                <span class="rainbow" aria-label={SURPRISE}>
                  {SURPRISE.split("").map((ch, i) => (
                    <span style={`--i: ${i};`} aria-hidden="true">{ch}</span>
                  ))}
                </span>
              </li>
            </ul>
            <a class="run-link" href={EVENTS.wednesday}>Strava event ↗</a>
          </div>
        </article>

        <article class="run">
          <figure class="duo">
            <Image
              src={lidoPhoto}
              alt="Breakfast on the wall at il Lido"
              widths={[480, 800]}
              sizes="(max-width: 900px) 92vw, 45vw"
            />
          </figure>
          <div class="run-body">
            <div class="run-head">
              <h3 class="display">Fri</h3>
              <span class="bib">0600 · il Lido</span>
            </div>
            <p>Beach during the summer, suburbs in the winter — and sometimes the CBD.</p>
            <ul class="sched">
              {FRIDAY.map(({ week, session }) => (
                <li><span class="wk">{week}</span><span>{session}</span></li>
              ))}
            </ul>
            <a class="run-link" href={EVENTS.friday}>Strava event ↗</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ traditions ============ -->
  <section class="section trads">
    <div class="wrap">
      <div class="kicker" data-rv>
        <h2 class="display">The Traditions</h2>
        <span class="mono">When it's not Wednesday or Friday</span>
      </div>
      <ol class="trad-list">
        {TRADITIONS.map(({ name, blurb }, i) => (
          <li data-rv style={i ? `transition-delay: ${i * 0.08}s;` : undefined}>
            <span class="num">{String(i + 1).padStart(2, "0")}</span>
            <h3>{name}</h3>
            <p>{blurb}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <Marquee text="AMEN SCOUNDRELS • SEE YOU AT 0530" reverse />
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    padding-top: clamp(36px, 5vw, 60px);
  }
  .hero h1 {
    display: grid;
  }
  .hero .line-clip {
    overflow: hidden;
  }
  .hero .line {
    display: block;
    font-size: clamp(58px, 10.5vw, 152px);
  }
  .hero .line.pink {
    color: var(--pink);
  }
  .hero .line.outline {
    color: transparent;
    -webkit-text-stroke: 2.5px var(--ink);
  }
  :global(html.js-anim) .hero .line {
    animation: line-rise 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  :global(html.js-anim) .hero .line-clip:nth-child(2) .line {
    animation-delay: 0.1s;
  }
  :global(html.js-anim) .hero .line-clip:nth-child(3) .line {
    animation-delay: 0.2s;
  }
  @keyframes line-rise {
    from { translate: 0 110%; }
    to { translate: 0 0; }
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 36px;
    border-top: 2px solid var(--line);
    border-bottom: 2px solid var(--line);
    padding: 16px 0;
    margin-top: clamp(24px, 3vw, 36px);
  }
  .hero-meta .mono b {
    color: var(--pink);
    font-weight: 700;
  }

  .ctas {
    display: flex;
    gap: 16px;
    padding-top: 28px;
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 2px solid var(--line);
    padding: 15px 28px;
    transition: transform 100ms ease, box-shadow 100ms ease;
  }
  .btn:hover {
    transform: translate(-3px, -3px);
    box-shadow: 5px 5px 0 var(--pink);
  }
  .btn:active {
    transform: translate(0, 0);
    box-shadow: 0 0 0 var(--pink);
  }
  .btn-solid {
    background: var(--gold);
    color: var(--espresso);
  }

  /* hero photo strip */
  .strip {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    margin-top: clamp(32px, 4vw, 48px);
    border-top: 2px solid var(--line);
  }
  .strip :global(.duo) {
    border-right: 2px solid var(--line);
  }
  .strip :global(.duo:last-child) {
    border-right: 0;
  }
  .strip :global(.duo img) {
    height: clamp(220px, 24vw, 300px);
  }

  /* ---- manifesto (full-bleed pink in both themes) ---- */
  .manifesto {
    background: var(--pink);
    color: var(--crema);
    padding: clamp(64px, 8vw, 96px) 0;
  }
  .manifesto .creed {
    font-size: clamp(40px, 5.6vw, 76px);
    max-width: 12em;
    /* looser than the display default so comma descenders don't collide */
    line-height: 1.05;
  }
  .manifesto .creed .out {
    display: inline-block;
    color: transparent;
    -webkit-text-stroke: 2px var(--crema);
    cursor: default;
  }
  .manifesto .creed .out:hover {
    animation: mental 0.45s ease;
  }
  @keyframes mental {
    20% { rotate: -2.5deg; translate: -2px 0; }
    40% { rotate: 2.5deg; translate: 2px 0; }
    60% { rotate: -1.5deg; }
    80% { rotate: 1.5deg; }
  }
  .manifesto .creed .gold {
    color: var(--gold);
  }
  .stamp {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 2.5px solid var(--crema);
    padding: 10px 20px;
    rotate: -2deg;
    margin-top: 44px;
  }
  :global(html.js-anim) .stamp {
    opacity: 0;
  }
  :global(html.js-anim) .stamp:global(.stamped) {
    animation: stamp-in 0.5s cubic-bezier(0.2, 1.5, 0.4, 1) 0.25s both;
  }
  @keyframes stamp-in {
    from { opacity: 0; scale: 2.2; rotate: 6deg; }
    to { opacity: 1; scale: 1; rotate: -2deg; }
  }
  .manifesto .creed-foot {
    margin-top: 36px;
    max-width: 36em;
    font-size: 17px;
    color: #f6d7de;
  }

  /* ---- section scaffolding ---- */
  .section {
    padding: clamp(56px, 7vw, 88px) 0;
  }
  .kicker {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }
  .kicker h2 {
    font-size: clamp(44px, 5vw, 64px);
  }
  .kicker .mono {
    color: var(--ink-soft);
  }

  /* ---- weekly runs ---- */
  .run-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 2px solid var(--line);
  }
  .run {
    border-right: 2px solid var(--line);
  }
  .run:last-child {
    border-right: 0;
  }
  .run :global(.duo) {
    border-bottom: 2px solid var(--line);
  }
  .run :global(.duo img) {
    height: 260px;
  }
  .run-body {
    padding: 28px;
  }
  .run-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .run-head h3 {
    font-size: clamp(42px, 4vw, 56px);
  }
  .bib {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13.5px;
    letter-spacing: 0.1em;
    border: 2px solid var(--espresso);
    padding: 6px 12px;
    background: var(--gold);
    color: var(--espresso);
    rotate: 1.5deg;
    transition: rotate 0.25s cubic-bezier(0.2, 1.6, 0.4, 1);
  }
  .run:hover .bib {
    rotate: -1.5deg;
  }
  .run-body > p {
    margin-top: 14px;
    color: var(--ink-soft);
    font-size: 17px;
  }
  .sched {
    list-style: none;
    margin: 22px 0 0;
    padding: 0;
    border-top: 2px solid var(--line);
  }
  .sched li {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    padding: 11px 0;
    border-bottom: 1px solid var(--ink-soft);
    font-size: 16.5px;
    align-items: baseline;
    transition: padding-left 0.2s ease;
  }
  .sched li:hover {
    padding-left: 6px;
  }
  .sched .wk {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 13.5px;
    color: var(--pink);
    text-transform: uppercase;
  }

  /* rainbow letters (5th-week surprise) — sock-stripe rainbow, per-theme vars */
  .rainbow {
    font-weight: 700;
  }
  .rainbow span {
    display: inline-block;
  }
  .rainbow span:nth-child(5n + 1) { color: var(--rb1); }
  .rainbow span:nth-child(5n + 2) { color: var(--rb2); }
  .rainbow span:nth-child(5n + 3) { color: var(--rb3); }
  .rainbow span:nth-child(5n + 4) { color: var(--rb4); }
  .rainbow span:nth-child(5n + 5) { color: var(--rb5); }
  .sched li:hover .rainbow span {
    animation: rb-pop 0.5s ease;
    animation-delay: calc(var(--i) * 45ms);
  }
  @keyframes rb-pop {
    30% { translate: 0 -3px; }
  }

  .run-link {
    display: inline-block;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-bottom: 2px solid var(--pink);
    padding-bottom: 2px;
  }
  .run-link:hover {
    color: var(--pink);
  }

  /* ---- traditions ---- */
  .trads {
    padding-top: 0;
  }
  .trad-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .trad-list li {
    display: grid;
    grid-template-columns: 200px 1.1fr 1.2fr;
    gap: 32px;
    align-items: baseline;
    border-top: 2px solid var(--line);
    padding: 26px 0;
    transition: padding-left 0.25s ease;
  }
  .trad-list li:hover {
    padding-left: 14px;
  }
  .trad-list li:last-child {
    border-bottom: 2px solid var(--line);
  }
  .trad-list .num {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 2px var(--pink);
    transition: color 0.2s ease;
  }
  .trad-list li:hover .num {
    color: var(--pink);
  }
  .trad-list h3 {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: 30px;
    letter-spacing: 0.01em;
  }
  .trad-list p {
    color: var(--ink-soft);
    font-size: 17px;
  }

  /* ---- responsive ---- */
  @media (max-width: 900px) {
    .hero .line.outline {
      -webkit-text-stroke-width: 1.5px;
    }
    .hero-meta {
      flex-direction: column;
      gap: 8px;
    }
    .strip {
      grid-template-columns: 1fr;
    }
    .strip :global(.duo) {
      border-right: 0;
      border-bottom: 2px solid var(--line);
    }
    .strip :global(.duo:last-child) {
      border-bottom: 0;
    }
    .run-grid {
      grid-template-columns: 1fr;
    }
    .run {
      border-right: 0;
      border-bottom: 2px solid var(--line);
    }
    .run:last-child {
      border-bottom: 0;
    }
    .trad-list li {
      grid-template-columns: 1fr;
      gap: 8px;
      padding-block: 20px;
    }
    .trad-list .num {
      font-size: 56px;
    }
  }
  @media (max-width: 620px) {
    .ctas {
      flex-direction: column;
    }
    .btn {
      text-align: center;
    }
  }
</style>
