---
// Gold marquee strip. Decorative (aria-hidden); pauses on hover.
// `reverse` flips the travel direction for the closing band.
interface Props {
  text: string;
  reverse?: boolean;
}

const { text, reverse = false } = Astro.props;

// two identical spans; the track slides -50% for a seamless loop
const content = `${text} • `.repeat(6);
---

<div class:list={["marquee", { reverse }]} aria-hidden="true">
  <div class="track">
    <span>{content}</span>
    <span>{content}</span>
  </div>
</div>

<style>
  .marquee {
    overflow: hidden;
    background: var(--gold);
    color: var(--espresso);
    border-block: 2px solid var(--espresso);
    padding: 10px 0;
  }
  .track {
    display: flex;
    width: max-content;
    animation: slide var(--marquee-dur) linear infinite;
  }
  .marquee.reverse .track {
    animation-direction: reverse;
  }
  .marquee:hover .track {
    animation-play-state: paused;
  }
  .marquee span {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.2em;
    white-space: nowrap;
  }
  @keyframes slide {
    to { transform: translateX(-50%); }
  }
</style>
